<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BluetoothManager.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: Список устройств -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Обновленная панель управления с переключателем -->
            <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,0,0,20" VerticalAlignment="Center">
                <Button x:Name="ScanButton" x:Uid="ScanButton" Click="ScanButton_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                <ProgressRing x:Name="ScanProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>

                <!-- Переключатель отображения безымянных устройств -->
                <ToggleSwitch x:Name="ShowUnknownToggle" x:Uid="ShowUnknownSwitch" IsOn="False" VerticalAlignment="Center"/>
            </StackPanel>

            <ListView x:Name="DeviceListView" Grid.Row="1" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:BluetoothDeviceModel">
                        <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12" Margin="0,4,0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE702;" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="Bold" FontSize="14"/>
                                        <!-- Красивый шильдик технологии (Classic / BLE) -->
                                        <Border Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="6,1,6,1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind BluetoothType}" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{x:Bind Type, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Индикатор радара (Тепло/Холодно) -->
                                    <TextBlock Text="{x:Bind RadarIndicator, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Правая часть: Сила сигнала и Кнопка подключения -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="8">
                                    <!-- Уровень RSSI -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                        <FontIcon Glyph="&#xE8B1;" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind RssiString, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button Content="{x:Bind ConnectButtonText}" 
        Click="Connect_Click" 
        Tag="{x:Bind Id}" 
        Height="32" 
        Padding="12,0,12,0" 
        Style="{StaticResource AccentButtonStyle}"/>
                                </StackPanel>

                              
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ПРАВАЯ ЧАСТЬ: Терминал + Сервер -->
        <Grid Grid.Column="1" Margin="12,0,0,0" RowDefinitions="Auto, Auto, *, Auto">
            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,10">
                <TextBlock x:Name="StatusTextBlock" x:Uid="StatusTextBlock" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="ServerStatusTextBlock" Text="" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <Button x:Name="StartServerButton" x:Uid="StartServerButton" Click="StartServerButton_Click" Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="StopServerButton" x:Uid="StopServerButton" Click="StopServerButton_Click" IsEnabled="False"/>
            </StackPanel>

            <TextBox x:Name="TerminalLogTextBox" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalAlignment="Stretch" Margin="0,0,0,15"/>

            <Grid Grid.Row="3" ColumnDefinitions="*, Auto">
                <TextBox x:Name="InputTextBox" x:Uid="InputTextBox" IsEnabled="False" KeyDown="InputTextBox_KeyDown"/>
                <Button x:Name="SendButton" x:Uid="SendButton" Grid.Column="1" Click="SendButton_Click" IsEnabled="False" Margin="10,0,0,0" Style="{StaticResource AccentButtonStyle}"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
